  "stability": "stable",
  "maturity": "production",
  "engines": {
    "node": ">=18.0.0"
  },
  "requirements": {
    "npm": ">=9.0.0"
  },
  "cli": {
    "command": "freelang",
    "available": true,
    "subcommands": [
      "run <file>",
      "repl",
      "help",
      "version"
    ]
  },
  "exports": {
    "cli": "./dist/cli/index.js",
    "engine": "./dist/engine/auto-header.js",
    "lexer": "./dist/script-runner/lexer.js",
    "parser": "./dist/script-runner/parser.js",
    "compiler": "./dist/script-runner/compiler.js",
    "vm": "./dist/script-runner/vm.js",
    "checker": "./dist/script-runner/checker.js",
    "dashboard": "./dist/dashboard/dashboard.js"
  },
  "features": [
    "Self-hosting compiler (v2 can compile itself)",
    "Stack-based bytecode virtual machine",
    "Type inference and checking",
    "Advanced control flow (while, break, continue)",
    "Recursive functions",
    "Struct definitions with field mutation",
    "Array and collection operations",
    "Function declarations with parameters",
    "Bytecode optimization",
    "Error reporting with line numbers"
  ],
  "capabilities": {
    "compilation": {
      "language": "FreeLang",
      "target": "bytecode",
      "optimization": "basic",
      "parallelization": false
    },
    "execution": {
      "mode": "interpreted",
      "concurrency": "async-aware",
      "garbage_collection": "mark-sweep"
    },
    "type_system": {
      "inference": true,
      "strict_mode": false,
      "generic_types": false,
      "union_types": false
    }
  },
  "performance": {
    "compilation_time": "~100ms",
    "execution_mode": "direct-interpretation",
    "memory_footprint": "10MB-base",
    "optimization_level": "basic"
  },
