// Fibonacci Sequence - FreeLang v2
// Demonstrates recursive functions
// Run with: freelang run fibonacci.fl

fn fibonacci(n: i32) -> i32 {
  if n <= 1 {
    return n
  }
  return fibonacci(n - 1) + fibonacci(n - 2)
}

fn main(): void {
  println("Fibonacci Sequence (0..10):")

  var i: i32 = 0
  while i < 10 {
    println(str(fibonacci(i)))
    i = i + 1
  }
}
