{
  "name": "@freelang/runtime",
  "version": "2.2.0",
  "description": "FreeLang v2 - Production-ready self-hosting bytecode compiler with stack-based VM",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "clean": "rm -rf dist",
    "repl": "node dist/cli/index.js"
  },
  "keywords": [
    "language",
    "compiler",
    "bytecode",
    "vm",
    "self-hosting",
    "ai",
    "freelang",
    "programming-language"
  ],
  "author": "Claude AI",
  "license": "MIT",
  "bin": {
    "freelang": "./bin/freelang"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "express": "^5.2.1",
    "vscode-languageserver": "^8.1.0",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gogs.dclub.kr/kim/freelang-runtime.git"
  },
  "bugs": {
    "url": "https://gogs.dclub.kr/kim/freelang-runtime/issues"
  },
  "homepage": "https://gogs.dclub.kr/kim/freelang-runtime",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "RELEASE_v2.2.0.md",
    ".kpm-manifest.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "kpm": {
    "category": "language-runtime",
    "subcategory": "bytecode-compiler",
    "tags": [
      "programming-language",
      "compiler",
      "runtime",
      "bytecode-vm",
      "self-hosting",
      "ai-compiler"
    ],
    "entry": "dist/cli/index.js",
    "cli": true,
    "stability": "stable",
    "maturity": "production",
    "dependencies": [],
    "exports": {
      "cli": "./dist/cli/index.js",
      "engine": "./dist/engine/auto-header.js",
      "lexer": "./dist/script-runner/lexer.js",
      "parser": "./dist/script-runner/parser.js",
      "compiler": "./dist/script-runner/compiler.js",
      "vm": "./dist/script-runner/vm.js",
      "checker": "./dist/script-runner/checker.js"
    },
    "features": [
      "Self-hosting compiler (v2 can compile itself)",
      "Stack-based bytecode virtual machine",
      "Type inference and checking",
      "Advanced control flow (while, break, continue)",
      "Struct definitions with field mutation",
      "Recursive functions",
      "Array and collection operations",
      "Function declarations with parameters"
    ]
  }
}
